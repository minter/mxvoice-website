---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Open Graph -->
    <meta property="og:title" content="Mx. Voice - Improv Audio Software" />
    <meta property="og:description" content="The software you've trusted for 20 years to make your shows amazing. Rebuilt for modern performance." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://mxvoice.app" />
    <meta property="og:image" content="https://mxvoice.app/og-image.png" />
    <meta property="og:site_name" content="Mx. Voice" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Mx. Voice - Improv Audio Software" />
    <meta name="twitter:description" content="The software you've trusted for 20 years to make your shows amazing. Rebuilt for modern performance." />

    <title>Mx. Voice :: {title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=UA-167062269-1"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'UA-167062269-1');
    </script>

    <style is:global>
      @import '../styles/global.css';
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
