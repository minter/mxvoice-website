---
import Base from './Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import DocsSidebar from '../components/DocsSidebar.astro';

interface Props {
  frontmatter?: {
    title: string;
    subtitle?: string;
    image?: string;
  };
  title?: string;
  subtitle?: string;
  image?: string;
}

const { frontmatter, title: directTitle, subtitle: directSubtitle, image: directImage } = Astro.props;
const title = frontmatter?.title ?? directTitle ?? 'Documentation';
const subtitle = frontmatter?.subtitle ?? directSubtitle ?? '';
const image = frontmatter?.image ?? directImage;
const currentPath = Astro.url.pathname;
---

<Base title={title} description={subtitle} image={image}>
  <Navbar />

  <div class="hero hero-docs">
    <div class="container text-center">
      <h1>{title}</h1>
      {subtitle && <h2>{subtitle}</h2>}
    </div>
  </div>

  <div class="section">
    <div class="container">
      <div class="docs-layout">
        <DocsSidebar currentPath={currentPath} />
        <div class="docs-content">
          <slot />
        </div>
      </div>
    </div>
  </div>

  <Footer />
</Base>
